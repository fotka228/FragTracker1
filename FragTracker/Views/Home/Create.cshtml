@model FragTracker.Models.ProPlayer

@{
    ViewData["Title"] = "Додати гравця";
}

<h1>Додати гравця</h1>

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create">
            <div class="form-group mb-3">
                <label>Нікнейм</label>
                <input asp-for="Nickname" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label>Команда</label>
                <input asp-for="Team" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label>Гра (CS2 / Dota 2)</label>
                <input asp-for="Game" class="form-control" />
            </div>
            <div class="form-group mb-3">
                <label>Рейтинг</label>
                <input asp-for="Rating" class="form-control" type="number" />
            </div>
            <button type="submit" class="btn btn-success">Зберегти</button>
            <a asp-action="Index" class="btn btn-secondary">Назад</a>
        </form>
    </div>
</div>